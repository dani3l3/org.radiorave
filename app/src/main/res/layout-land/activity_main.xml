<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:animateLayoutChanges="true">

    <ImageView
        android:id="@+id/video_view_fullscreen"
        android:contentDescription="@string/app_name"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/black"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.40"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/img_sound"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="#dcdcdc"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_radiorave"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.07"
        app:layout_constraintStart_toStartOf="@+id/video_view_fullscreen"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_sound_example"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:scrollHorizontally="true"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="70dp"
        android:text="@string/title_sound_example"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/video_view_fullscreen"
        app:layout_constraintEnd_toEndOf="@+id/video_view_fullscreen"
        app:layout_constraintHorizontal_bias="0.060"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <TextView
        android:id="@+id/home_text_row1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_text_row1"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintTop_toBottomOf="@+id/tv_sound_example" />

    <TextView
        android:id="@+id/home_text_row2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_text_row2"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintTop_toBottomOf="@+id/home_text_row1" />

    <TextView
        android:id="@+id/home_text_row3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_text_row3"
        android:autoLink="web"
        android:textColorLink="@color/transparent_grey"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginTop="25dp"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintTop_toBottomOf="@+id/home_text_row2" />


    <ImageButton
        android:id="@+id/btn_play_pause"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:background="@drawable/ic_play"
        android:backgroundTint="@color/transparent_grey"
        android:backgroundTintMode="add"
        android:scaleType="centerCrop"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/playpause"
        app:layout_constraintBottom_toBottomOf="@+id/img_sound"
        app:layout_constraintEnd_toEndOf="@+id/img_sound"
        app:layout_constraintStart_toStartOf="@+id/img_sound"
        app:layout_constraintTop_toTopOf="@+id/img_sound" />


</androidx.constraintlayout.widget.ConstraintLayout>
